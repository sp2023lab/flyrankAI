APP_NAME=FlyRank PDF Report Generator
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://report_user:report_password@db:5432/report_db
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
ARTIFACTS_DIR=/app/artifacts
ENABLE_SCHEDULED_REPORTS=false
SCHEDULE_HOUR_UTC=8
SCHEDULE_MINUTE_UTC=0

AI_PROVIDER=groq
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=openai/gpt-oss-20b
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=1
AI_RETRY_BACKOFF_SECONDS=0.5
GROQ_INPUT_COST_PER_MILLION=0.075
GROQ_OUTPUT_COST_PER_MILLION=0.30
